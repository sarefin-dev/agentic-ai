# LangChain Configuration
# =======================

# Model Provider Selection
# Options: "ollama", "google_genai", "openai", "anthropic"
MODEL_PROVIDER=google_genai

# Model Name
# Examples:
#   - Ollama: "llama3.2", "llama2", "mistral"
#   - Google Gemini: "gemini-2.0-flash", "gemini-1.5-pro"
#   - OpenAI: "gpt-4o", "gpt-4-turbo", "gpt-3.5-turbo"
#   - Anthropic Claude: "claude-opus-4-1", "claude-sonnet-4"
MODEL_NAME=gemini-2.0-flash

# API Keys (only needed for cloud-based providers)
# Leave empty if using local Ollama

# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API Key
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude API Key
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Ollama Configuration
# Only needed if your Ollama server is not on localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
